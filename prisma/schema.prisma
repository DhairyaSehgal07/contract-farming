// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGING_DIRECTOR
  PROGRAMME_MANAGER
  ACCOUNTS_SETTLEMENTS_MANAGER
  FIELD_OPERATIONS_MANAGER
  ACCOUNTS_SEEDS_SUPPLY_MANAGER
  LOGISTICS_EXECUTIVE
  FIELD_OFFICER
  USER
}

enum RequisitionStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum DispatchStatus {
  OPEN
  CLOSED
}

enum DispatchLotStatus {
  PENDING
  RECEIVED
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(USER)
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  stationId     String?
  station       Station?  @relation(fields: [stationId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions             Session[]
  accounts             Account[]
  requisitionsCreated  Requisition[] @relation("RequisitionCreatedBy")
  requisitionsReviewed Requisition[] @relation("RequisitionReviewedBy")
  lotsReceived         DispatchLot[] @relation("LotReceivedBy")
  stockTransfersCreated StockTransfer[] @relation("StockTransferCreatedBy")

  @@index([stationId])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// main app MASTER models

model Station {
  id         String     @id @default(cuid())
  name       String
  city       String?
  state      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  localities     Locality[]
  farmers        Farmer[]
  farmerFamilies FarmerFamily[]
  users          User[]

  @@map("station")
}

model Locality {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stationId      String
  station        Station        @relation(fields: [stationId], references: [id], onDelete: Cascade)
  farmers        Farmer[]
  farmerFamilies FarmerFamily[]

  @@index([stationId])
  @@map("locality")
}

model FarmerFamily {
  id            String @id @default(cuid())
  accountNumber String @unique
  name          String

  stationId  String
  station    Station  @relation(fields: [stationId], references: [id], onDelete: Restrict)
  localityId String
  locality   Locality @relation(fields: [localityId], references: [id], onDelete: Restrict)

  members   Farmer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stationId])
  @@index([localityId])
  @@map("farmer_family")
}

model Farmer {
  id            String @id @default(cuid())
  name          String
  accountNumber String @unique

  mobileNumber  String
  aadharNumber  String  @unique
  panCardNumber String? @unique

  bankAccountName   String?
  bankName          String?
  bankAccountNumber String?
  bankIfscCode      String?
  bankBranchName    String?

  contractUrl String?

  stationId String
  station   Station @relation(fields: [stationId], references: [id], onDelete: Restrict)

  localityId String
  locality   Locality @relation(fields: [localityId], references: [id], onDelete: Restrict)

  familyId String?
  family   FarmerFamily? @relation(fields: [familyId], references: [id], onDelete: SetNull)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  requisitions Requisition[]
  stockBalances FarmerStockBalance[]
  fields        FarmerField[]
  transfersFrom StockTransfer[] @relation("TransferFromFarmer")
  transfersTo   StockTransfer[] @relation("TransferToFarmer")

  @@index([stationId])
  @@index([localityId])
  @@index([familyId])
  @@map("farmer")
}

enum FieldActivityRound {
  FIRST
  SECOND
}

model FarmerField {
  id          String  @id @default(cuid())
  name        String
  geoLocation String
  acres       Decimal @db.Decimal(10, 2)

  farmerId String
  farmer   Farmer @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  plantations  FieldPlantation[]
  irrigations  FieldIrrigation[]
  dehaulming   FieldDehaulming[]
  rouging      FieldRouging[]
  stripTests   FieldStripTest[]
  harvests     FieldHarvest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmerId, name])
  @@index([farmerId])
  @@map("farmer_field")
}

model FieldPlantation {
  id           String   @id @default(cuid())
  fieldId      String
  field        FarmerField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  varietyId    String
  variety      Variety  @relation(fields: [varietyId], references: [id], onDelete: Restrict)
  sizeId       String
  size         Size     @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  bagCount     Decimal  @db.Decimal(12, 2)
  acresPlanted Decimal  @db.Decimal(10, 2)
  plantedAt    DateTime @db.Date
  imageUrl     String?
  remarks      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fieldId])
  @@index([varietyId])
  @@index([sizeId])
  @@map("field_plantation")
}

model FieldIrrigation {
  id          String   @id @default(cuid())
  fieldId     String
  field       FarmerField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  cycleNumber Int
  irrigatedAt DateTime @db.Date
  imageUrl    String?
  remarks     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fieldId, cycleNumber])
  @@index([fieldId])
  @@map("field_irrigation")
}

model FieldDehaulming {
  id           String             @id @default(cuid())
  fieldId      String
  field        FarmerField        @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  round        FieldActivityRound
  activityDate DateTime           @db.Date
  result       String?
  remarks      String?
  imageUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fieldId])
  @@map("field_dehaulming")
}

model FieldRouging {
  id           String   @id @default(cuid())
  fieldId      String
  field        FarmerField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  activityDate DateTime @db.Date
  result       String?
  remarks      String?
  imageUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fieldId])
  @@map("field_rouging")
}

model FieldStripTest {
  id           String             @id @default(cuid())
  fieldId      String
  field        FarmerField        @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  round        FieldActivityRound
  activityDate DateTime           @db.Date
  result       String?
  remarks      String?
  imageUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fieldId])
  @@map("field_strip_test")
}

model FieldHarvest {
  id           String   @id @default(cuid())
  fieldId      String
  field        FarmerField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  activityDate DateTime @db.Date
  result       String?
  remarks      String?
  imageUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fieldId])
  @@map("field_harvest")
}

model Variety {
  id        String   @id @default(cuid())
  name      String   @unique

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  requisitions Requisition[]
  stockBalances FarmerStockBalance[]
  transferLines StockTransferLine[]
  fieldPlantations FieldPlantation[]

  @@map("variety")
}

model Location {
  id       String @id @default(cuid())
  name     String @unique
  category String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatchesFrom Dispatch[] @relation("DispatchFromLocation")

  @@map("location")
}

model Size {
  id          String   @id @default(cuid())
  name        String   @unique
  bagsPerAcre Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatchSizeLines DispatchRequisitionSizeLine[]
  stockBalances     FarmerStockBalance[]
  transferLines     StockTransferLine[]
  fieldPlantations  FieldPlantation[]

  @@map("size")
}

model Generation {
  id        String   @id @default(cuid())
  name      String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatchSizeLines DispatchRequisitionSizeLine[]
  stockBalances     FarmerStockBalance[]
  transferLines     StockTransferLine[]

  @@map("generation")
}

model FarmerStockBalance {
  id           String @id @default(cuid())
  farmerId     String
  farmer       Farmer @relation(fields: [farmerId], references: [id], onDelete: Restrict)
  varietyId    String
  variety      Variety @relation(fields: [varietyId], references: [id], onDelete: Restrict)
  sizeId       String
  size         Size @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Restrict)
  quantity     Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmerId, varietyId, sizeId, generationId])
  @@index([farmerId])
  @@index([varietyId])
  @@map("farmer_stock_balance")
}

model StockTransfer {
  id           String   @id @default(cuid())
  transferDate DateTime @db.Date
  remarks      String?

  fromFarmerId String
  fromFarmer   Farmer @relation("TransferFromFarmer", fields: [fromFarmerId], references: [id], onDelete: Restrict)
  toFarmerId   String
  toFarmer     Farmer @relation("TransferToFarmer", fields: [toFarmerId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User @relation("StockTransferCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  lines StockTransferLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transferDate])
  @@index([fromFarmerId])
  @@index([toFarmerId])
  @@index([createdById])
  @@map("stock_transfer")
}

model StockTransferLine {
  id         String @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  varietyId    String
  variety      Variety @relation(fields: [varietyId], references: [id], onDelete: Restrict)
  sizeId       String
  size         Size @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Restrict)
  quantity     Decimal @db.Decimal(12, 2)

  @@index([transferId])
  @@index([varietyId])
  @@index([sizeId])
  @@index([generationId])
  @@map("stock_transfer_line")
}

model RolePermission {
  id       String @id @default(cuid())
  role     Role
  resource String
  action   String

  @@unique([role, resource, action])
  @@index([role])
  @@map("role_permission")
}

model Requisition {
  id                   String            @id @default(cuid())
  requisitionDate      DateTime          @db.Date
  requestedDeliveryDate DateTime          @db.Date
  approvedDeliveryDate DateTime?         @db.Date
  acres                Decimal?          @db.Decimal(10, 2)
  initialQuantity      Decimal?          @db.Decimal(12, 2)
  fulfilledQuantity    Decimal           @default(0) @db.Decimal(12, 2)
  fulfilledAcres       Decimal           @default(0) @db.Decimal(10, 2)
  status               RequisitionStatus @default(PENDING)
  remarks              String?
  rejectionRemarks     String?

  farmerId  String
  farmer    Farmer  @relation(fields: [farmerId], references: [id], onDelete: Restrict)
  varietyId String
  variety   Variety @relation(fields: [varietyId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User   @relation("RequisitionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  reviewedById String?
  reviewedBy   User?     @relation("RequisitionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  approvalDate DateTime? @db.Date
  rejectionDate DateTime? @db.Date

  dispatchAssignments DispatchRequisition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmerId])
  @@index([varietyId])
  @@index([createdById])
  @@index([reviewedById])
  @@index([status])
  @@index([requisitionDate])
  @@index([requestedDeliveryDate])
  @@map("requisition")
}

model Dispatch {
  id                   String         @id @default(cuid())
  status               DispatchStatus @default(OPEN)
  dispatchDate         DateTime?      @db.Date
  dateOfReceiving      DateTime?      @db.Date
  truckNumber          String?
  manualGatePassNumber String?
  weightSlipNumber     String?
  grossWeight          Decimal?  @db.Decimal(12, 2)
  tareWeight           Decimal?  @db.Decimal(12, 2)
  netWeight            Decimal?  @db.Decimal(12, 2)
  averageWeightPerBag  Decimal?  @db.Decimal(12, 2)
  driverMobileNumber   String?
  remarks              String?

  locationId   String?
  location     Location?   @relation("DispatchFromLocation", fields: [locationId], references: [id], onDelete: Restrict)
  toLocation   String?

  requisitions DispatchRequisition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dispatchDate])
  @@index([locationId])
  @@index([status])
  @@map("dispatch")
}

model DispatchRequisition {
  id            String @id @default(cuid())
  dispatchId    String
  dispatch      Dispatch    @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  requisitionId String
  requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Restrict)

  sizeLines DispatchRequisitionSizeLine[]
  lot       DispatchLot?

  @@unique([dispatchId, requisitionId])
  @@index([dispatchId])
  @@index([requisitionId])
  @@map("dispatch_requisition")
}

model DispatchLot {
  id                    String            @id @default(cuid())
  dispatchRequisitionId String            @unique
  dispatchRequisition   DispatchRequisition @relation(fields: [dispatchRequisitionId], references: [id], onDelete: Cascade)
  status                DispatchLotStatus @default(PENDING)
  receivedAt            DateTime?
  receivedById          String?
  receivedBy            User?             @relation("LotReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  otpSentAt             DateTime?
  otpVerifiedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([receivedById])
  @@map("dispatch_lot")
}

model OtpChallenge {
  id           String   @id @default(cuid())
  purpose      String
  referenceId  String
  mobileNumber String
  codeHash     String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([purpose, referenceId])
  @@map("otp_challenge")
}

model DispatchRequisitionSizeLine {
  id                    String @id @default(cuid())
  dispatchRequisitionId String
  dispatchRequisition   DispatchRequisition @relation(fields: [dispatchRequisitionId], references: [id], onDelete: Cascade)
  sizeId                String
  size                  Size                @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  generationId          String
  generation            Generation          @relation(fields: [generationId], references: [id], onDelete: Restrict)
  quantity              Decimal             @db.Decimal(12, 2)

  @@unique([dispatchRequisitionId, sizeId, generationId])
  @@index([sizeId])
  @@index([generationId])
  @@map("dispatch_requisition_size_line")
}